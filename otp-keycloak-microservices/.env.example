# Keycloak Configuration
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to git!

# Keycloak Server URL
KEYCLOAK_SERVER_URL=http://localhost:8180

# Keycloak Realm Name
KEYCLOAK_REALM=myrealm

# Backend Service Client Configuration
KEYCLOAK_CLIENT_ID=backend-service
KEYCLOAK_CLIENT_SECRET=your-client-secret-from-keycloak

# Service Account Credentials (NOT admin!)
# Follow KEYCLOAK_SERVICE_ACCOUNT_SETUP.md to create service account
KEYCLOAK_SERVICE_USERNAME=service-user-manager
KEYCLOAK_SERVICE_PASSWORD=your-strong-service-password

# MPIN Encryption Key (Generate a secure random key)
# Generate with: openssl rand -base64 32
MPIN_ENCRYPTION_KEY=your-base64-encoded-encryption-key
